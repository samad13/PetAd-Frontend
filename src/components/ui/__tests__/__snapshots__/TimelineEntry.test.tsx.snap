exports[`TimelineEntry > renders SDK-driven entry with transaction link 1`] = `
<div>
  <li
    aria-label="Status changed from ESCROW CREATED to ESCROW FUNDED by John Doe (adopter) Reason: Funds deposited successfully at 3/26/2024, 10:00:00 AM"
    class="flex items-start gap-3 p-3 border-b border-gray-100 last:border-b-0 hover:bg-gray-50 transition-colors"
  >
    <div
      class="flex items-center gap-2 flex-shrink-0"
    >
      <div
        class="group relative inline-flex"
      >
        <span
          class="status-badge status-badge--gray"
        >
          <span>
            Escrow Created
          </span>
        </span>
        <div
          class="status-badge__tooltip-wrapper"
        >
          <div
            class="status-badge__tooltip"
          >
            Escrow has been created but not funded yet.
          </div>
        </div>
      </div>
      <svg
        aria-hidden="true"
