          href="https://stellar.expert/explorer/public/tx/abcd1234567890abcd1234567890abcd12345678"
          rel="noopener noreferrer"
          target="_blank"
        >
          abcd1234…12345678
          <svg
            aria-hidden="true"
            class="lucide lucide-external-link w-4 h-4"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
